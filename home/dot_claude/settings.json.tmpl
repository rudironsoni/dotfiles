{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "docker",
      "git"
    ],
    "network": {
      "allowUnixSockets": [
        "/var/run/docker.sock"
      ],
      "allowLocalBinding": true
    },
    "allowUnsandboxedCommands": false
  },
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.synthetic.new/anthropic",
    "ANTHROPIC_AUTH_TOKEN": {{ if lookPath "op" }}{{ output "op" "read" "op://vault-prd/Synthetic API Key/credential" | trim | quote }}{{ else }}""{{ end }},
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "hf:moonshotai/Kimi-K2.5",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "hf:moonshotai/Kimi-K2.5",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "hf:MiniMaxAI/MiniMax-M2.5",
    "CLAUDE_CODE_SUBAGENT_MODEL": "hf:moonshotai/Kimi-K2.5",
    "CLAUDE_AGENT_MODEL": "hf:moonshotai/Kimi-K2.5",
    "CLAUDE_CODE_BASH_SANDBOX_SHOW_INDICATOR": "true",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "true",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "true",
    "CLAUDE_CODE_DISABLE_BACKGROUND_TASKS": "false",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "true",
    "CLAUDE_CODE_PLAN_MODE_REQUIRED": "false",
    "CLAUDE_CODE_PLAN_MODE_INTERVIEW_PHASE": "true",
    "CLAUDE_CODE_ENABLE_TASKS": "true",
    "DISABLE_TELEMETRY": "true",
    "ENABLE_BETA_TRACING_DETAILED": "true",
    "ENABLE_BTW": "true",
    "ENABLE_LSP_TOOL": "true",
    "ENABLE_SESSION_BACKGROUNDING": "true",
    "ENABLE_TOOL_SEARCH": "true",
    "FORCE_AUTOUPDATE_PLUGINS": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "deny": [
      "Bash(git commit --no-verify:*)",
      "Bash(git remote add:*)",
      "Bash(git remote set-url:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(rm -rf //**)",
      "Bash(rm -rf ~/**)",
      "Read(.env*)",
      "Read(credentials/)"
    ],
    "allow": [
      "mcp__serena"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/synthetic-statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "beads@beads-marketplace": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "safety-net@cc-marketplace": true,
    "security-guidance@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "statusline-tools@claude-settings": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "compound-engineering@compound-engineering-plugin": true,
    "plannotator@plannotator": true
  },
  "extraKnownMarketplaces": {
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    }
  },
  "outputStyle": "Learning",
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux"
}
