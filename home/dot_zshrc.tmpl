# ~/.zshrc - Zsh configuration
# Managed by chezmoi: https://chezmoi.io/

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# ============================================================================
# History
# ============================================================================
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt hist_ignore_all_dups
setopt hist_ignore_space
setopt hist_reduce_blanks
setopt share_history

# ============================================================================
# Autoload Utilities
# ============================================================================
autoload -Uz colors
autoload -Uz compinit
autoload -Uz promptinit

# Initialize colors
colors

# Initialize completion with caching for performance
# Only rebuild completion cache once per day
autoload -Uz compinit
if [[ -n ${ZDOTDIR}/.zcompdump(#qN.mh+24) ]]; then
    compinit
else
    compinit -C  # Use cached completions
fi

# ============================================================================
# Completion
# ============================================================================
# Case-insensitive completion
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
# Group completions by type
zstyle ':completion:*' menu select
zstyle ':completion:*' group-name ''
# Show descriptions for completions
zstyle ':completion:*:descriptions' format '%B%d%b'

# ============================================================================
# PATH Configuration
# ============================================================================
# Build PATH components in order of priority
path_components=()

# macOS Homebrew
{{- if eq .chezmoi.os "darwin" }}
path_components+=("/opt/homebrew/bin" "/opt/homebrew/sbin")
{{- else }}
# Linuxbrew
if [[ -d /home/linuxbrew/.linuxbrew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
{{- end }}

# Development tools
path_components+=("$HOME/.bun/bin")
path_components+=("$HOME/.local/share/pnpm")
path_components+=("$HOME/.opencode/bin")
path_components+=("$HOME/.local/bin")

# Add existing PATH
path_components+=("$PATH")

# Join and export
export PATH=$(IFS=:; echo "${path_components[*]}")

# ============================================================================
# Node Version Manager (NVM)
# ============================================================================
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# ============================================================================
# Editor
# ============================================================================
export EDITOR={{ (output "sh" "-c" "cat $HOME/.config/editors 2>/dev/null || echo vim") | trim | quote }}
export VISUAL="$EDITOR"

# ============================================================================
# Language and Locale
# ============================================================================
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# ============================================================================
# Prompt (Oh My Posh)
# ============================================================================
# Use Oh My Posh if available, fall back to built-in
if command -v oh-my-posh &> /dev/null; then
    eval "$(oh-my-posh init zsh --config https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/emodipt-extend.omp.json)"
else
    promptinit
    prompt adam1
fi

# ============================================================================
# Keybindings
# ============================================================================
# Use emacs keybindings (default is vi)
bindkey -e

# History search with prefix matching
# Type "cd" and press Up to search history for "cd ..." commands
autoload -U history-search-end
zle -N history-beginning-search-backward-end history-search-end
zle -N history-beginning-search-forward-end history-search-end
bindkey "^[[A" history-beginning-search-backward-end   # Up arrow
bindkey "^[[B" history-beginning-search-forward-end    # Down arrow

# ============================================================================
# Directory Navigation
# ============================================================================
# Auto-cd into directories
setopt autocd
# Correct cd typos
setopt cdablevars
# Pushd to home on empty cd
setopt auto_pushd
# Don't duplicate previous entries
setopt pushd_ignore_dups

# ============================================================================
# Aliases
# ============================================================================
# General
alias ll='ls -la'
alias la='ls -A'
alias l='ls -CF'

# Safety
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# Git
alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline --graph --decorate'

# Utilities
alias cat='bat'
{{- if eq .chezmoi.os "darwin" }}
alias ls='ls -G'
{{- else }}
alias ls='ls --color=auto'
{{- end }}

# ============================================================================
# OS-Specific Configuration
# ============================================================================
{{- if eq .chezmoi.os "darwin" }}
# macOS-specific
export CLICOLOR=1
alias update='brew update && brew upgrade'
{{- else if eq .chezmoi.os "linux" }}
# Linux-specific
alias update='sudo apt update && sudo apt upgrade'
{{- end }}

# ============================================================================
# FZF Integration
# ============================================================================
[ -f "$HOME/.fzf.zsh" ] && source "$HOME/.fzf.zsh"

# ============================================================================
# Zsh Plugins (managed by chezmoi via .chezmoiexternal.toml)
# ============================================================================

# zsh-completions (must be loaded before compinit)
if [ -f "$HOME/.config/zsh/plugins/zsh-completions/zsh-completions.plugin.zsh" ]; then
    fpath=("$HOME/.config/zsh/plugins/zsh-completions/src" $fpath)
fi

# zsh-autosuggestions
if [ -f "$HOME/.config/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh"
    ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8'
fi

# fzf-tab (improves fzf integration with completions)
if [ -f "$HOME/.config/zsh/plugins/fzf-tab/fzf-tab.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/fzf-tab/fzf-tab.plugin.zsh"
    # Preview directory contents with fzf-tab
    zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls -la $realpath'
    zstyle ':fzf-tab:complete:ls:*' fzf-preview 'cat $realpath'
fi

# colorize (colorize command output)
if [ -f "$HOME/.config/zsh/plugins/colorize/colorize.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/colorize/colorize.plugin.zsh"
fi

# zsh-syntax-highlighting (must be sourced last)
if [ -f "$HOME/.config/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi

# zsh-opencode-tab (OpenCode tab completion)
if [ -f "$HOME/.config/zsh/plugins/zsh-opencode-tab/zsh-opencode-tab.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-opencode-tab/zsh-opencode-tab.plugin.zsh"
fi

# zsh-indent-control (Smart indentation)
if [ -f "$HOME/.config/zsh/plugins/zsh-indent-control/zsh-indent-control.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-indent-control/zsh-indent-control.plugin.zsh"
fi

# fd-zsh (fd command aliases and completions)
if [ -f "$HOME/.config/zsh/plugins/fd-zsh/fd-zsh.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/fd-zsh/fd-zsh.plugin.zsh"
fi

# zsh-fzf-packagemanager (package manager integration with fzf)
if [ -f "$HOME/.config/zsh/plugins/zsh-fzf-packagemanager/zsh-fzf-packagemanager.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-fzf-packagemanager/zsh-fzf-packagemanager.plugin.zsh"
fi

# jq-zsh-plugin (jq integration)
if [ -f "$HOME/.config/zsh/plugins/jq-zsh-plugin/jq-zsh.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/jq-zsh-plugin/jq-zsh.plugin.zsh"
fi

# k3d-oh-my-zsh-plugin (k3d completions)
if [ -f "$HOME/.config/zsh/plugins/k3d-oh-my-zsh-plugin/k3d-oh-my-zsh-plugin.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/k3d-oh-my-zsh-plugin/k3d-oh-my-zsh-plugin.plugin.zsh"
fi

# zsh-k9s (k9s completions)
if [ -f "$HOME/.config/zsh/plugins/zsh-k9s/zsh-k9s.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-k9s/zsh-k9s.plugin.zsh"
fi

# zsh-mise (mise completions)
if [ -f "$HOME/.config/zsh/plugins/zsh-mise/zsh-mise.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-mise/zsh-mise.plugin.zsh"
fi

# zsh-ssh-agent (ssh-agent management)
if [ -f "$HOME/.config/zsh/plugins/zsh-ssh-agent/zsh-ssh-agent.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-ssh-agent/zsh-ssh-agent.plugin.zsh"
fi

# ssh-host (ssh host completions)
if [ -f "$HOME/.config/zsh/plugins/ssh-host/ssh-host.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/ssh-host/ssh-host.plugin.zsh"
fi

# xdg-basedirs (XDG directories)
if [ -f "$HOME/.config/zsh/plugins/xdg-basedirs/xdg-basedirs.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/xdg-basedirs/xdg-basedirs.plugin.zsh"
fi

# zsh-fzf-git-worktree (git worktree with fzf)
if [ -f "$HOME/.config/zsh/plugins/zsh-fzf-git-worktree/zsh-fzf-git-worktree.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-fzf-git-worktree/zsh-fzf-git-worktree.plugin.zsh"
fi

# git-fuzzy (fuzzy git operations)
if [ -f "$HOME/.config/zsh/plugins/git-fuzzy/git-fuzzy.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/git-fuzzy/git-fuzzy.plugin.zsh"
fi

# zman (zsh help pages)
if [ -f "$HOME/.config/zsh/plugins/zman/zman.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zman/zman.plugin.zsh"
fi

# zsh-you-should-use (reminds aliases)
if [ -f "$HOME/.config/zsh/plugins/zsh-you-should-use/you-should-use.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-you-should-use/you-should-use.plugin.zsh"
fi

# ============================================================================
# Zsh Completions
# ============================================================================

# 1Password CLI completions
if [ -f "$HOME/.config/zsh/plugins/1password-op.plugin.zsh/1password-op.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/1password-op.plugin.zsh/1password-op.plugin.zsh"
fi

# Bash completions fallback
if [ -f "$HOME/.config/zsh/plugins/zsh-bash-completions-fallback/zsh-bash-completions-fallback.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-bash-completions-fallback/zsh-bash-completions-fallback.plugin.zsh"
fi

# Claude Code completions
if [ -f "$HOME/.config/zsh/plugins/claude-code-zsh-completion/claude-code-zsh-completion.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/claude-code-zsh-completion/claude-code-zsh-completion.plugin.zsh"
fi

# Chezmoi completions
if [ -f "$HOME/.config/zsh/plugins/zsh-chezmoi/zsh-chezmoi.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-chezmoi/zsh-chezmoi.plugin.zsh"
fi

# cod - completion daemon
if [ -f "$HOME/.config/zsh/plugins/cod/cod.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/cod/cod.plugin.zsh"
fi

# zsh-completion-sync
if [ -f "$HOME/.config/zsh/plugins/zsh-completion-sync/zsh-completion-sync.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-completion-sync/zsh-completion-sync.plugin.zsh"
fi

# Copilot completions
if [ -f "$HOME/.config/zsh/plugins/copilot.zsh/copilot.zsh" ]; then
    source "$HOME/.config/zsh/plugins/copilot.zsh/copilot.zsh"
fi

# ctop completions
if [ -f "$HOME/.config/zsh/plugins/ctop/ctop.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/ctop/ctop.plugin.zsh"
fi

# Docker completions
if [ -f "$HOME/.config/zsh/plugins/docker-zsh-completion/docker-zsh-completion.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/docker-zsh-completion/docker-zsh-completion.plugin.zsh"
fi

# Fancy completions
if [ -f "$HOME/.config/zsh/plugins/zsh-fancy-completions/zsh-fancy-completions.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-fancy-completions/zsh-fancy-completions.plugin.zsh"
fi

# fzf zsh completions
if [ -f "$HOME/.config/zsh/plugins/fzf-zsh-completions/fzf-zsh-completions.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/fzf-zsh-completions/fzf-zsh-completions.plugin.zsh"
fi

# Helmfile completions
if [ -f "$HOME/.config/zsh/plugins/zsh-helmfile/zsh-helmfile.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-helmfile/zsh-helmfile.plugin.zsh"
fi

# Justfile completions
if [ -f "$HOME/.config/zsh/plugins/zsh-justfile/zsh-justfile.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-justfile/zsh-justfile.plugin.zsh"
fi

# Kafka completions
if [ -f "$HOME/.config/zsh/plugins/kafka-zsh-completions/kafka-zsh-completions.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/kafka-zsh-completions/kafka-zsh-completions.plugin.zsh"
fi

# Kind completions
if [ -f "$HOME/.config/zsh/plugins/zsh-kind/zsh-kind.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-kind/zsh-kind.plugin.zsh"
fi

# Kompose completions
if [ -f "$HOME/.config/zsh/plugins/kompose/kompose.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/kompose/kompose.plugin.zsh"
fi

# kubectl-fzf completions
if [ -f "$HOME/.config/zsh/plugins/kubectl-fzf/kubectl-fzf.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/kubectl-fzf/kubectl-fzf.plugin.zsh"
fi

# Kustomize completions
if [ -f "$HOME/.config/zsh/plugins/oh-my-kustomize/oh-my-kustomize.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/oh-my-kustomize/oh-my-kustomize.plugin.zsh"
fi

# ngrok completions (only if ngrok is installed and working)
if command -v ngrok &>/dev/null && ngrok --version &>/dev/null && [ -f "$HOME/.config/zsh/plugins/ngrok.plugin.zsh/ngrok.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/ngrok.plugin.zsh/ngrok.plugin.zsh"
fi

# Ollama completions
if [ -f "$HOME/.config/zsh/plugins/zsh-ollama-completion/zsh-ollama-completion.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-ollama-completion/zsh-ollama-completion.plugin.zsh"
fi

# Poetry completions (skip - requires oh-my-zsh/zinit compatibility)
# Plugin uses $+commands syntax incompatible with bare zsh
# if command -v poetry &>/dev/null; then
#     poetry completions zsh > "${ZSH_CACHE_DIR:-$HOME/.cache/zsh}/completions/_poetry"
# fi

# Pytest-fzf completions
if [ -f "$HOME/.config/zsh/plugins/zsh-pytest-fzf/zsh-pytest-fzf.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-pytest-fzf/zsh-pytest-fzf.plugin.zsh"
fi

# SSH completions (enhanced)
if [ -f "$HOME/.config/zsh/plugins/zsh-ssh/zsh-ssh.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-ssh/zsh-ssh.plugin.zsh"
fi

# Talosctl completions
if [ -f "$HOME/.config/zsh/plugins/talosctl-zsh-plugin/talosctl-zsh-plugin.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/talosctl-zsh-plugin/talosctl-zsh-plugin.plugin.zsh"
fi

# uv completions
if [ -f "$HOME/.config/zsh/plugins/zsh-uv/zsh-uv.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-uv/zsh-uv.plugin.zsh"
fi

# ============================================================================
# Claude Code Configuration
# ============================================================================
# Model configuration
export ANTHROPIC_DEFAULT_OPUS_MODEL=hf:moonshotai/Kimi-K2.5
export ANTHROPIC_DEFAULT_SONNET_MODEL=hf:moonshotai/Kimi-K2.5
export ANTHROPIC_DEFAULT_HAIKU_MODEL=hf:MiniMaxAI/MiniMax-M2.5
export CLAUDE_CODE_SUBAGENT_MODEL=hf:moonshotai/Kimi-K2.5

# Privacy configuration
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Experimental features
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# Claude Code aliases
alias cc="claude --verbose --dangerously-skip-permissions"
alias ccti="claude --verbose --dangerously-skip-permissions --teammate-mode in-process"
alias cctt="claude --verbose --dangerously-skip-permissions --teammate-mode tmux"

# ============================================================================
# Secrets (via 1Password)
# ============================================================================
{{- if lookPath "op" }}
# GitHub Personal Access Token
export GITHUB_MCP_TOKEN={{ output "op" "read" (printf "op://%s/%s/%s" .secrets.github_mcp_token.vault .secrets.github_mcp_token.item .secrets.github_mcp_token.field) | trim | quote }}
export GITHUB_PERSONAL_ACCESS_TOKEN=${GITHUB_MCP_TOKEN}

# Synthetic API Key
export SYNTHETIC_API_KEY={{ output "op" "read" (printf "op://%s/%s/%s" .secrets.synthetic_api_key.vault .secrets.synthetic_api_key.item .secrets.synthetic_api_key.field) | trim | quote }}
export ANTHROPIC_AUTH_TOKEN=${SYNTHETIC_API_KEY}

# Anthropic API Base URL
export ANTHROPIC_BASE_URL="https://api.synthetic.new/anthropic"
{{- else }}
# 1Password CLI not available - secrets must be set manually or via .zshrc.local
# export GITHUB_MCP_TOKEN=""
# export GITHUB_PERSONAL_ACCESS_TOKEN=${GITHUB_MCP_TOKEN}
# export SYNTHETIC_API_KEY=""
# export ANTHROPIC_AUTH_TOKEN=${SYNTHETIC_API_KEY}
# export ANTHROPIC_BASE_URL="https://api.synthetic.new/anthropic"
{{- end }}

# ============================================================================
# Additional Configurations
# ============================================================================
# Source additional zsh configurations if they exist
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"

# Shellfish integration (if exists)
test -e "$HOME/.shellfishrc" && source "$HOME/.shellfishrc"

# ============================================================================
# Opentmux Configuration
# ============================================================================
export OPENCODE_PORT=4096
alias opencodemux='opentmux'
