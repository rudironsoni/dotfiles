# ~/.zshrc - Zsh configuration
# Managed by chezmoi: https://chezmoi.io/

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# ============================================================================
# History
# ============================================================================
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt hist_ignore_all_dups
setopt hist_ignore_space
setopt hist_reduce_blanks
setopt share_history

# ============================================================================
# Autoload Utilities
# ============================================================================
autoload -Uz colors
autoload -Uz compinit
autoload -Uz promptinit

# Initialize colors
colors

# Initialize completion with caching for performance
# Only rebuild completion cache once per day
autoload -Uz compinit
if [[ -n ${ZDOTDIR}/.zcompdump(#qN.mh+24) ]]; then
    compinit
else
    compinit -C  # Use cached completions
fi

# ============================================================================
# Completion
# ============================================================================
# Case-insensitive completion
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
# Group completions by type
zstyle ':completion:*' menu select
zstyle ':completion:*' group-name ''
# Show descriptions for completions
zstyle ':completion:*:descriptions' format '%B%d%b'

# ============================================================================
# PATH Configuration
# ============================================================================
# Build PATH components in order of priority
path_components=()

# macOS Homebrew
{{- if eq .chezmoi.os "darwin" }}
path_components+=("/opt/homebrew/bin" "/opt/homebrew/sbin")
{{- else }}
# Linuxbrew
if [[ -d /home/linuxbrew/.linuxbrew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
{{- end }}

# Development tools
path_components+=("$HOME/.bun/bin")
path_components+=("$HOME/.local/share/pnpm")
path_components+=("$HOME/.opencode/bin")
path_components+=("$HOME/.local/bin")

# Add existing PATH
path_components+=("$PATH")

# Join and export
export PATH=$(IFS=:; echo "${path_components[*]}")

# ============================================================================
# Node Version Manager (NVM)
# ============================================================================
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# ============================================================================
# Editor
# ============================================================================
export EDITOR={{ (output "sh" "-c" "cat $HOME/.config/editors 2>/dev/null || echo vim") | trim | quote }}
export VISUAL="$EDITOR"

# ============================================================================
# Language and Locale
# ============================================================================
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# ============================================================================
# Prompt (Oh My Posh)
# ============================================================================
# Use Oh My Posh if available, fall back to built-in
if command -v oh-my-posh &> /dev/null; then
    eval "$(oh-my-posh init zsh --config https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/emodipt-extend.omp.json)"
else
    promptinit
    prompt adam1
fi

# ============================================================================
# Keybindings
# ============================================================================
# Use emacs keybindings (default is vi)
bindkey -e

# ============================================================================
# Directory Navigation
# ============================================================================
# Auto-cd into directories
setopt autocd
# Correct cd typos
setopt cdablevars
# Pushd to home on empty cd
setopt auto_pushd
# Don't duplicate previous entries
setopt pushd_ignore_dups

# ============================================================================
# Aliases
# ============================================================================
# General
alias ll='ls -la'
alias la='ls -A'
alias l='ls -CF'

# Safety
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# Git
alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline --graph --decorate'

# Utilities
alias cat='bat'
{{- if eq .chezmoi.os "darwin" }}
alias ls='ls -G'
{{- else }}
alias ls='ls --color=auto'
{{- end }}

# ============================================================================
# OS-Specific Configuration
# ============================================================================
{{- if eq .chezmoi.os "darwin" }}
# macOS-specific
export CLICOLOR=1
alias update='brew update && brew upgrade'
{{- else if eq .chezmoi.os "linux" }}
# Linux-specific
alias update='sudo apt update && sudo apt upgrade'
{{- end }}

# ============================================================================
# FZF Integration
# ============================================================================
[ -f "$HOME/.fzf.zsh" ] && source "$HOME/.fzf.zsh"

# ============================================================================
# Zsh Plugins (managed by chezmoi via .chezmoiexternal.toml)
# ============================================================================

# zsh-completions (must be loaded before compinit)
if [ -f "$HOME/.config/zsh/plugins/zsh-completions/zsh-completions.plugin.zsh" ]; then
    fpath=("$HOME/.config/zsh/plugins/zsh-completions/src" $fpath)
fi

# zsh-autosuggestions
if [ -f "$HOME/.config/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh"
    ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8'
fi

# fzf-tab (improves fzf integration with completions)
if [ -f "$HOME/.config/zsh/plugins/fzf-tab/fzf-tab.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/fzf-tab/fzf-tab.plugin.zsh"
    # Preview directory contents with fzf-tab
    zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls -la $realpath'
    zstyle ':fzf-tab:complete:ls:*' fzf-preview 'cat $realpath'
fi

# colorize (colorize command output)
if [ -f "$HOME/.config/zsh/plugins/colorize/colorize.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/colorize/colorize.plugin.zsh"
fi

# fast-syntax-highlighting (better/faster syntax highlighting, must be sourced last)
if [ -f "$HOME/.config/zsh/plugins/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
fi

# zsh-opencode-tab (OpenCode tab completion)
if [ -f "$HOME/.config/zsh/plugins/zsh-opencode-tab/zsh-opencode-tab.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-opencode-tab/zsh-opencode-tab.plugin.zsh"
fi

# zsh-indent-control (Smart indentation)
if [ -f "$HOME/.config/zsh/plugins/zsh-indent-control/zsh-indent-control.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/zsh-indent-control/zsh-indent-control.plugin.zsh"
fi

# fd-zsh (fd command aliases and completions)
if [ -f "$HOME/.config/zsh/plugins/fd-zsh/fd-zsh.plugin.zsh" ]; then
    source "$HOME/.config/zsh/plugins/fd-zsh/fd-zsh.plugin.zsh"
fi

# ============================================================================
# Claude Code Configuration
# ============================================================================
# Model configuration
export ANTHROPIC_DEFAULT_OPUS_MODEL=hf:moonshotai/Kimi-K2.5
export ANTHROPIC_DEFAULT_SONNET_MODEL=hf:moonshotai/Kimi-K2.5
export ANTHROPIC_DEFAULT_HAIKU_MODEL=hf:MiniMaxAI/MiniMax-M2.5
export CLAUDE_CODE_SUBAGENT_MODEL=hf:moonshotai/Kimi-K2.5

# Privacy configuration
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Experimental features
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# Claude Code aliases
alias cc="claude --verbose --dangerously-skip-permissions"
alias ccti="claude --verbose --dangerously-skip-permissions --teammate-mode in-process"
alias cctt="claude --verbose --dangerously-skip-permissions --teammate-mode tmux"

# ============================================================================
# Secrets (via 1Password)
# ============================================================================
{{- if lookPath "op" }}
# GitHub Personal Access Token
export GITHUB_MCP_TOKEN={{ output "op" "read" (printf "op://%s/%s/%s" .secrets.github_mcp_token.vault .secrets.github_mcp_token.item .secrets.github_mcp_token.field) | trim | quote }}
export GITHUB_PERSONAL_ACCESS_TOKEN=${GITHUB_MCP_TOKEN}

# Synthetic API Key
export SYNTHETIC_API_KEY={{ output "op" "read" (printf "op://%s/%s/%s" .secrets.synthetic_api_key.vault .secrets.synthetic_api_key.item .secrets.synthetic_api_key.field) | trim | quote }}
export ANTHROPIC_AUTH_TOKEN=${SYNTHETIC_API_KEY}

# Anthropic API Base URL
export ANTHROPIC_BASE_URL="https://api.synthetic.new/anthropic"
{{- else }}
# 1Password CLI not available - secrets must be set manually or via .zshrc.local
# export GITHUB_MCP_TOKEN=""
# export GITHUB_PERSONAL_ACCESS_TOKEN=${GITHUB_MCP_TOKEN}
# export SYNTHETIC_API_KEY=""
# export ANTHROPIC_AUTH_TOKEN=${SYNTHETIC_API_KEY}
# export ANTHROPIC_BASE_URL="https://api.synthetic.new/anthropic"
{{- end }}

# ============================================================================
# Additional Configurations
# ============================================================================
# Source additional zsh configurations if they exist
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"

# Shellfish integration (if exists)
test -e "$HOME/.shellfishrc" && source "$HOME/.shellfishrc"
