#!/bin/bash
# Declarative package installation for Linux
# Runs when .chezmoidata/packages.yaml changes
# https://www.chezmoi.io/user-guide/advanced/install-packages-declaratively/

set -euo pipefail

echo "=== Installing packages for Linux (declarative) ==="

# Detect package manager
detect_package_manager() {
    if command -v apt &> /dev/null; then
        echo "apt"
    elif command -v dnf &> /dev/null; then
        echo "dnf"
    elif command -v pacman &> /dev/null; then
        echo "pacman"
    elif command -v zypper &> /dev/null; then
        echo "zypper"
    else
        echo "unknown"
    fi
}

PKG_MANAGER=$(detect_package_manager)
echo "Detected package manager: $PKG_MANAGER"

# Install common packages
{{ range .packages.linux.common -}}
PACKAGE="{{ . }}"
if ! command -v "$PACKAGE" &> /dev/null 2>&1; then
    echo "  → Installing $PACKAGE..."
    case "$PKG_MANAGER" in
        apt)
            sudo apt-get install -y "$PACKAGE" || echo "  ⚠ Failed to install $PACKAGE"
            ;;
        dnf)
            sudo dnf install -y "$PACKAGE" || echo "  ⚠ Failed to install $PACKAGE"
            ;;
        pacman)
            sudo pacman -Sy --needed --noconfirm "$PACKAGE" || echo "  ⚠ Failed to install $PACKAGE"
            ;;
        zypper)
            sudo zypper install -y "$PACKAGE" || echo "  ⚠ Failed to install $PACKAGE"
            ;;
    esac
else
    echo "  ✓ $PACKAGE already installed"
fi
{{ end -}}

# Install distro-specific packages
echo "Installing $PKG_MANAGER specific packages..."
{{ range $manager, $packages := .packages.linux -}}
{{ if ne $manager "common" -}}
if [ "$PKG_MANAGER" = "{{ $manager }}" ]; then
{{ range $packages -}}
    PACKAGE="{{ . }}"
    if ! command -v "$PACKAGE" &> /dev/null 2>&1; then
        echo "  → Installing $PACKAGE..."
        case "$PKG_MANAGER" in
            apt)
                sudo apt-get install -y "$PACKAGE" || echo "  ⚠ Failed to install $PACKAGE"
                ;;
            dnf)
                sudo dnf install -y "$PACKAGE" || echo "  ⚠ Failed to install $PACKAGE"
                ;;
            pacman)
                sudo pacman -Sy --needed --noconfirm "$PACKAGE" || echo "  ⚠ Failed to install $PACKAGE"
                ;;
            zypper)
                sudo zypper install -y "$PACKAGE" || echo "  ⚠ Failed to install $PACKAGE"
                ;;
        esac
    else
        echo "  ✓ $PACKAGE already installed"
    fi
{{ end -}}
fi
{{ end -}}
{{ end -}}

# Note: 1Password CLI is installed automatically during chezmoi init
# via hooks.read-source-state.pre (see .install-1password.sh)

# Install oh-my-posh
echo "Installing oh-my-posh..."
if ! command -v oh-my-posh &> /dev/null; then
    curl -s https://ohmyposh.dev/install.sh | bash -s || echo "  ⚠ Failed to install oh-my-posh"
else
    echo "  ✓ oh-my-posh already installed"
fi

echo "=== Linux package installation complete ==="
