#!/usr/bin/env pwsh
# Package installation script for Windows
# Runs once before any files are applied
# https://www.chezmoi.io/reference/special-files/chezmoiscripts/

#Requires -RunAsAdministrator

param(
    [switch]$Force
)

$ErrorActionPreference = "Stop"

Write-Host "=== Installing packages for Windows ===" -ForegroundColor Cyan

# Check if winget is available
if (-not (Get-Command winget -ErrorAction SilentlyContinue)) {
    Write-Error "winget not found. Please install App Installer from Microsoft Store."
    exit 1
}

# Define packages to install
$packages = @(
    # Core tools
    @{ Id = "twpayne.chezmoi"; Name = "Chezmoi" }
    @{ Id = "Git.Git"; Name = "Git" }
    @{ Id = "AgileBits.1Password.CLI"; Name = "1Password CLI" }

    # Terminal
    @{ Id = "Microsoft.WindowsTerminal"; Name = "Windows Terminal" }
    @{ Id = "JanDeDobbeleer.OhMyPosh"; Name = "Oh My Posh" }

    # Shell tools
    @{ Id = "fzf"; Name = "fzf" }
    @{ Id = "BurntSushi.ripgrep.MSVC"; Name = "ripgrep" }
    @{ Id = "sharkdp.fd"; Name = "fd" }
    @{ Id = "sharkdp.bat"; Name = "bat" }
    @{ Id = "eza-community.eza"; Name = "eza" }

    # Development
    @{ Id = "GitHub.cli"; Name = "GitHub CLI" }
    @{ Id = "JesseDuffield.lazygit"; Name = "lazygit" }
)

# Install each package
foreach ($pkg in $packages) {
    $id = $pkg.Id
    $name = $pkg.Name

    Write-Host "Checking $name..." -NoNewline

    $installed = winget list --id $id --exact 2>$null | Select-String $id

    if ($installed) {
        Write-Host " already installed" -ForegroundColor Green
    } else {
        Write-Host " installing..." -ForegroundColor Yellow
        try {
            winget install --id $id --exact --accept-source-agreements --accept-package-agreements
            Write-Host "  Installed $name" -ForegroundColor Green
        } catch {
            Write-Warning "Failed to install $name`: $_"
        }
    }
}

# Install Scoop packages (optional)
if (Get-Command scoop -ErrorAction SilentlyContinue) {
    Write-Host "Installing Scoop packages..." -ForegroundColor Cyan

    $scoopPackages = @(
        "btop"
        "nvm"
    )

    foreach ($pkg in $scoopPackages) {
        try {
            scoop install $pkg
        } catch {
            Write-Warning "Failed to install $pkg via Scoop`: $_"
        }
    }
}

# Configure PowerShell execution policy
Write-Host "Configuring PowerShell execution policy..." -ForegroundColor Cyan
Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser -Force

# Install PowerShell modules
$modules = @(
    "PSReadLine"
    "Terminal-Icons"
)

foreach ($module in $modules) {
    if (-not (Get-Module -ListAvailable -Name $module)) {
        Write-Host "Installing PowerShell module: $module" -ForegroundColor Yellow
        Install-Module -Name $module -Scope CurrentUser -Force -AllowClobber
    }
}

Write-Host "=== Windows package installation complete ===" -ForegroundColor Green
