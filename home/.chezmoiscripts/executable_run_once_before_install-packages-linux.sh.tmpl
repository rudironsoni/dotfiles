#!/bin/bash
# Package installation script for Linux
# Runs once before any files are applied
# https://www.chezmoi.io/reference/special-files/chezmoiscripts/

set -euo pipefail

echo "=== Installing packages for Linux ==="

# Detect package manager
detect_package_manager() {
    if command -v apt &> /dev/null; then
        echo "apt"
    elif command -v dnf &> /dev/null; then
        echo "dnf"
    elif command -v pacman &> /dev/null; then
        echo "pacman"
    elif command -v zypper &> /dev/null; then
        echo "zypper"
    else
        echo "unknown"
    fi
}

PKG_MANAGER=$(detect_package_manager)
echo "Detected package manager: $PKG_MANAGER"

# Install chezmoi if not present
if ! command -v chezmoi &> /dev/null; then
    echo "Installing chezmoi..."
    sh -c "$(curl -fsLS get.chezmoi.io)"
    export PATH="$HOME/.local/bin:$PATH"
fi

# Install packages based on package manager
case "$PKG_MANAGER" in
    apt)
        echo "Using apt (Debian/Ubuntu)..."
        sudo apt-get update
        sudo apt-get install -y \
            git curl wget \
            zsh bash fish \
            tmux fzf \
            ripgrep fd-find bat eza \
            btop \
            gh || true

        # Install 1Password CLI
        if ! command -v op &> /dev/null; then
            echo "Installing 1Password CLI..."
            curl -sS https://downloads.1password.com/linux/keys/1password.asc | \
                sudo gpg --dearmor --output /usr/share/keyrings/1password-archive-keyring.gpg
            echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/$(dpkg --print-architecture) stable main" | \
                sudo tee /etc/apt/sources.list.d/1password.list
            sudo apt-get update
            sudo apt-get install -y 1password-cli || true
        fi

        # Install lazygit
        if ! command -v lazygit &> /dev/null; then
            LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
            curl -Lo lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
            tar xf lazygit.tar.gz lazygit
            sudo install lazygit /usr/local/bin
            rm lazygit lazygit.tar.gz
        fi
        ;;

    dnf)
        echo "Using dnf (Fedora/RHEL)..."
        sudo dnf install -y \
            git curl wget \
            zsh bash fish \
            tmux fzf \
            ripgrep fd-find bat eza \
            btop \
            gh lazygit || true
        ;;

    pacman)
        echo "Using pacman (Arch)..."
        sudo pacman -Sy --needed --noconfirm \
            git curl wget \
            zsh bash fish \
            tmux fzf \
            ripgrep fd bat eza \
            btop \
            github-cli lazygit || true
        ;;

    zypper)
        echo "Using zypper (openSUSE)..."
        sudo zypper install -y \
            git curl wget \
            zsh bash fish \
            tmux fzf \
            ripgrep fd bat eza \
            btop || true
        ;;

    *)
        echo "Unknown package manager. Please install packages manually."
        echo "Required packages: git, curl, wget, zsh, bash, tmux, fzf, ripgrep, fd, bat, eza, btop"
        ;;
esac

# Install oh-my-posh (cross-platform)
if ! command -v oh-my-posh &> /dev/null; then
    echo "Installing oh-my-posh..."
    curl -s https://ohmyposh.dev/install.sh | bash -s
fi

echo "=== Linux package installation complete ==="
