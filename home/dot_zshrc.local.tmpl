# ~/.zshrc.local - Machine-specific Zsh configuration
# Managed by chezmoi: https://chezmoi.io/
#
# This file contains machine-specific settings and secrets that are not
# suitable for the main dotfiles repository. Secrets are fetched from
# 1Password using the chezmoi template system.
#
# NOTE: This file is automatically generated. Edit the template at:
# ~/.local/share/chezmoi/home/dot_zshrc.local.tmpl

# ============================================================================
# 1Password Service Account Token
# ============================================================================
# Required for 1Password CLI to authenticate in automated environments
# The service account token grants access to specific vaults without
# interactive sign-in. This is used for:
#   - CI/CD pipelines
#   - Automated scripts
#   - Non-interactive shells
#
# To create a service account:
#   op service-account create "Dotfiles Automation" --vault "Personal"
#
# Store the token in 1Password as "Service Account Token"
export OP_SERVICE_ACCOUNT_TOKEN={{ if lookPath "op" }}{{ output "op" "read" "op://Personal/Service Account Token/credential" | trim | quote }}{{ else }}""{{ end }}

# ============================================================================
# GitHub Tokens
# ============================================================================
# GITHUB_MCP_TOKEN is already set in ~/.zshrc via 1Password
# GITHUB_PERSONAL_ACCESS_TOKEN is aliased to GITHUB_MCP_TOKEN
# Add any additional GitHub tokens here if needed for specific use cases

# ============================================================================
# Synthetic API (via ~/.zshrc)
# ============================================================================
# SYNTHETIC_API_KEY and ANTHROPIC_AUTH_TOKEN are already set in ~/.zshrc
# via 1Password lookups. Add overrides here if needed.

