# OpenCode Configuration
# Managed by chezmoi: https://chezmoi.io/
# https://github.com/redcode-labs/opencode/blob/main/README.md

# Editor
editor:
  fontSize: 14
  fontFamily: "Fira Code, JetBrains Mono, monospace"
  tabSize: 4
  theme: "default-dark"
  lineNumbers: true
  minimap: true
  wordWrap: "on"
  autoSave: true
  autoSaveDelay: 1000

# Terminal
terminal:
  shell: {{ env "SHELL" | default "/bin/zsh" | quote }}
  fontSize: 13
  fontFamily: "Fira Code, monospace"

# Keybindings (custom keybindings)
keybindings:
  # Navigation
  - key: "ctrl+p"
    action: "quickOpen"
  - key: "ctrl+shift+p"
    action: "commandPalette"
  - key: "ctrl+b"
    action: "toggleSidebar"
  - key: "ctrl+`"
    action: "toggleTerminal"
  
  # Editing
  - key: "ctrl+d"
    action: "findNext"
  - key: "ctrl+shift+d"
    action: "copyLineDown"
  - key: "alt+up"
    action: "moveLineUp"
  - key: "alt+down"
    action: "moveLineDown"
  
  # Git
  - key: "ctrl+g"
    action: "gitView"

# Git
git:
  autoFetch: true
  autoCommit: false
  autoPush: false

# Extensions
extensions:
  autoUpdate: true
  ignoreRecommendations: false

# Workbench
workbench:
  activityBar: true
  statusBar: true
  sidebar: true

# Search
search:
  useGlobalIgnoreFiles: true
  followSymlinks: false

# Language servers
languageServers:
  {{- if eq .chezmoi.os "darwin" }}
  # macOS-specific
  {{- else if eq .chezmoi.os "linux" }}
  # Linux-specific
  {{- end }}

# Snippets
snippets: []

# Themes
themes:
  - name: "default-dark"
    type: "dark"
  - name: "default-light"
    type: "light"
