{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@tarquinen/opencode-dcp@1.2.7",
    "@franlol/opencode-md-table-formatter@0.0.3",
    "cc-safety-net",
    "envsitter-guard"
  ],
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--enable-web-dashboard",
        "false",
        "--project",
        "."
      ],
      "enabled": true
    },
    "microsoftdocs-mcp": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp",
      "enabled": true
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "provider": {
    "openai": {
      "options": {
        "websearch_cited": {
          "model": "gpt-5.4"
        }
      }
    }
  },
  "permission": {
    "task": "deny",
    "context7_*": "deny",
    "exa_*": "deny",
    "gh_grep_*": "deny",
    "kagi_*": "deny",
    "webfetch": "deny",
    "worktree_*": "deny"
  },
  "agent": {
    "researcher": {
      "permission": {
        "context7_*": "allow",
        "exa_*": "allow",
        "gh_grep_*": "allow",
        "kagi_*": "deny",
        "webfetch": "allow",
        "write": "deny",
        "edit": "deny",
        "plan_read": "deny",
        "todoread": "deny",
        "bash": {
          "*": "deny",
          "gh repo view*": "allow",
          "gh pr view*": "allow",
          "gh pr list*": "allow",
          "gh issue view*": "allow",
          "gh issue list*": "allow",
          "npm view*": "allow",
          "pip show*": "allow",
          "cargo search*": "allow",
          "man *": "allow",
          "tldr *": "allow",
          "jq *": "allow",
          "grep *": "allow",
          "rg *": "allow"
        }
      }
    },
    "scribe": {
      "permission": {
        "bash": {
          "*": "deny"
        },
        "edit": "allow",
        "glob": "allow",
        "read": "allow",
        "write": "allow",
        "plan_read": "deny",
        "todoread": "deny"
      }
    },
    "coder": {
      "permission": {
        "context7_*": "deny",
        "exa_*": "deny",
        "gh_grep_*": "deny",
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "plan_read": "deny",
        "todoread": "deny"
      }
    },
    "reviewer": {
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "rg *": "allow"
        },
        "plan_read": "allow",
        "delegation_read": "allow",
        "delegation_list": "allow"
      }
    }
  },
  "instructions": [
    "./tools/philosophy.md"
  ]
}
