# lazygit configuration
# Managed by chezmoi: https://chezmoi.io/
# https://github.com/jesseduffield/lazygit/blob/master/docs/CONFIG.md

# User interface
gui:
  # Theme
  theme:
    activeBorderColor:
      - green
    inactiveBorderColor:
      - white
    selectedRangeBgColor:
      - blue
    # OS-specific selected line color
{{- if eq .chezmoi.os "darwin" }}
    selectedLineBgColor:
      - cyan
{{- else }}
    selectedLineBgColor:
      - blue
{{- end }}

  # Refresh interval (ms)
  refreshInterval: 100

  # Side panel width (0-100)
  sidePanelWidth: 0.2

  # Split diff view
  splitDiff: auto

# Commands
commands:
  # Custom commands
  - key: 'f'
    description: 'Fetch all'
    command: 'git fetch --all'
    prompts:
      - key: 'confirm'
        title: 'Run git fetch?'
        initialValue: true

# Custom menus
customCommands:
  # Example custom menu
  - key: 'r'
    name: 'Rebase interactive'
    command: 'git rebase -i HEAD~{{ `{{.Form.SelectedLocalCommits}}` }}'
    context: 'commits'

# Git flow
git:
  # Padding between commits
  commitPrefix: ''

  # Side-by-side diff
  splitDiff: auto

  # Show diff refresh spinner
  showDiffSpinner: true

  # Skip staged submodules
  skipStagedSubmodules: false

# Notifications
notifications:
  # Sound
  sound: true

  # Fade out duration (ms)
  fadeOutDuration: 5000
