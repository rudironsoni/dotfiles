# Ranger configuration file
# Managed by chezmoi
# https://ranger.github.io/

# =============================================================================
# General Settings
# =============================================================================

# Show hidden files by default
set show_hidden true

# Show line numbers
set line_numbers relative

# Draw borders around columns
set draw_borders both

# Preview files
set preview_files true
set preview_directories true
set preview_images true
set preview_images_method sixel

# Use the external preview script if available
set use_preview_script true
set preview_script ~/.config/ranger/scope.sh

# =============================================================================
# Appearance
# =============================================================================

# Set the view mode (multipane, miller)
set viewmode miller

# Set column ratios
set column_ratios 1,3,4

# Show a progress bar for copying
set draw_progress_bar_in_status_bar true

# Draw percentage in the status bar
set draw_progress_bar_in_task_view true

# Show file sizes in human readable format
set human_readable_sizes true

# Use unicode characters
set unicode_ellipsis true

# Show free disk space in the status bar
set free_space true

# =============================================================================
# Behavior
# =============================================================================

# Enable VCS integration (shows git status)
set vcs_aware true
set vcs_backend_git enabled

# Automatically count files in directories
set autoupdate_cumulative_size_parent true

# Confirm before quitting
set confirm_on_delete multiple

# Sanitize pasted filenames
set sanitize_timestamps true

# Open all images in a directory when viewing one
set open_all_images true

# Save history
set save_console_history true
set max_console_history_size 100

# Save bookmarks
set save_bookmarks true
set max_history_size 50

# =============================================================================
# Mappings (Vim-like)
# =============================================================================

# Basic navigation
map j move down
map k move up
map h move left
map l move right

# Page scrolling
map <C-d> move down 10
map <C-u> move up 10

# Half page scrolling
map <C-f> move down 0.5 pages
map <C-b> move up 0.5 pages

# First/last
map gg move to=0
map G move to=-1

# Search
map / search
map ? search_back
map n search_next
map N search_previous

# Quick exit
map q quit
map Q quitall

# File operations
map <ENTER> edit
map r rename
map dd delete
map yy copy
map pp paste
map cc cut

# Toggle hidden files
map zh set show_hidden!

# Fuzzy finder integration
map <C-p> fzf_select
map <C-f> fzf_locate

# =============================================================================
# Commands
# =============================================================================

# Create a new file
map nf console touch%space

# Create a new directory
map nd console mkdir%space

# Create a new directory and cd into it
map nD console mkdir%space
cd

# Open shell here
map s shell
map S shell -f

# Open with default application
map o open_with

# Extract archives
map x extract
map X extract_here

# Change permissions
map +c chmod

# Change ownership
map +o chown

# =============================================================================
# Bookmarks
# =============================================================================

map gD cd ~/Downloads
map gd cd ~/Documents
map ge cd ~/Desktop
map gh cd ~
map gp cd ~/Pictures
map gv cd ~/Videos
map gc cd ~/.config
map gl cd ~/.local
map gs cd ~/src
map gt cd /tmp

# =============================================================================
# Theme Colors (One Dark inspired)
# =============================================================================

# Default colors
set colorscheme default

# Highlighting colors
set preview_files true
set preview_directories true
set preview_images true
