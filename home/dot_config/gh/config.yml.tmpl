# GitHub CLI configuration
# Managed by chezmoi: https://chezmoi.io/
# https://cli.github.com/manual/

git_protocol: https

# Editor
editor: {{ (output "sh" "-c" "cat $HOME/.config/editors 2>/dev/null || echo vim") | trim | quote }}

# Pager
pager: {{ if lookPath "delta" }}"delta"{{ else }}"cat"{{ end }}

# Aliases
aliases:
  co: checkout
  cr: create repo
  ls: repo list
  pl: pull
  ps: push
  br: branch

# gh auth status
# Run `gh auth login` to authenticate

# Note: Sensitive data like personal access tokens should not be stored here
# Use `gh auth status` to check authentication
