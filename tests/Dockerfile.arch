# ==============================================================================
# Docker Test Container - Arch Linux
# ==============================================================================
# This Dockerfile is used to test the dotfiles bootstrap on Arch Linux
#
# Build:   docker build -f tests/Dockerfile.arch -t dotfiles-test:arch .
# Run:     docker run --rm dotfiles-test:arch bash tests/test-chezmoi.sh
#
# ==============================================================================

FROM archlinux:latest

# Update system and install base dependencies
RUN pacman -Syu --noconfirm && \
    pacman -S --noconfirm \
    curl \
    wget \
    git \
    vim \
    ca-certificates-utils \
    base-devel \
    procps-ng \
    unzip \
    gnupg \
    python \
    python-yaml \
    jq \
    sudo

# Create test user with sudo access
RUN useradd -m -s /bin/bash testuser && \
    echo "testuser ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# Install chezmoi
RUN sh -c "$(curl -fsLS get.chezmoi.io)" -- -b /usr/local/bin

# Install 1Password CLI from AUR
# Import the 1Password signing key for the testuser
RUN sudo -u testuser bash -c 'gpg --keyserver keyserver.ubuntu.com --recv-keys 3FEF9748469ADBE15DA7CA80AC2D62742012EA22' && \
    sudo -u testuser bash -c 'cd /tmp && \
    git clone https://aur.archlinux.org/1password-cli.git && \
    cd 1password-cli && \
    makepkg -si --noconfirm' && \
    rm -rf /tmp/1password-cli

# Copy test scripts
COPY scripts/ /home/testuser/scripts/
COPY tests/ /home/testuser/tests/
RUN chmod +x /home/testuser/scripts/*.sh /home/testuser/tests/*.sh 2>/dev/null || true

# Set proper ownership
RUN chown -R testuser:testuser /home/testuser

# Copy entrypoint script (must be done as root)
COPY tests/docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Switch to test user
USER testuser
WORKDIR /home/testuser

# Set environment
ENV HOME=/home/testuser
ENV USER=testuser
ENV OP_SERVICE_ACCOUNT_TOKEN=""

# Default command
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["bash"]
