# ==============================================================================
# Docker Test Container - Fedora Latest
# ==============================================================================
# This Dockerfile is used to test the dotfiles bootstrap on Fedora
#
# Build:   docker build -f tests/Dockerfile.fedora -t dotfiles-test:fedora .
# Run:     docker run --rm dotfiles-test:fedora bash tests/test-chezmoi.sh
#
# ==============================================================================

FROM fedora:latest

# Install base dependencies
RUN dnf install -y \
    curl \
    wget \
    git \
    vim \
    ca-certificates \
    gcc \
    gcc-c++ \
    make \
    procps-ng \
    unzip \
    gnupg2 \
    python3 \
    python3-pyyaml \
    jq \
    && dnf clean all

# Create test user
RUN useradd -m -s /bin/bash testuser

# Install chezmoi
RUN sh -c "$(curl -fsLS get.chezmoi.io)" -- -b /usr/local/bin

# Try to install 1Password CLI (best effort - 1Password doesn't provide stable Fedora packages)
RUN curl -sS https://downloads.1password.com/linux/keys/1password.asc | \
    gpg --import || true && \
    (curl -sSL https://cache.agilebits.com/dist/1P/2P/op2/pkg/2.32.0/op_linux_amd64_v2.32.0.zip -o /tmp/op.zip && \
     unzip -o /tmp/op.zip -d /usr/local/bin/ && \
     chmod +x /usr/local/bin/op && \
     rm /tmp/op.zip) || \
    echo "1Password CLI installation skipped - will test without it"

# Copy test scripts
COPY scripts/ /home/testuser/scripts/
COPY tests/ /home/testuser/tests/
RUN chmod +x /home/testuser/scripts/*.sh /home/testuser/tests/*.sh 2>/dev/null || true

# Set proper ownership
RUN chown -R testuser:testuser /home/testuser

# Switch to test user
USER testuser
WORKDIR /home/testuser

# Set environment
ENV HOME=/home/testuser
ENV USER=testuser

# Default command
CMD ["bash"]
