# ==============================================================================
# Docker Test Container - Fedora Latest
# ==============================================================================
# This Dockerfile is used to test the dotfiles bootstrap on Fedora
#
# Build:   docker build -f tests/Dockerfile.fedora -t dotfiles-test:fedora .
# Run:     docker run --rm dotfiles-test:fedora bash tests/test-chezmoi.sh
#
# ==============================================================================

FROM fedora:latest

# Install base dependencies
RUN dnf install -y \
    curl \
    wget \
    git \
    vim \
    ca-certificates \
    gcc \
    gcc-c++ \
    make \
    procps-ng \
    unzip \
    gnupg2 \
    python3 \
    python3-pyyaml \
    jq \
    && dnf clean all

# Create test user
RUN useradd -m -s /bin/bash testuser

# Install chezmoi
RUN sh -c "$(curl -fsLS get.chezmoi.io)" -- -b /usr/local/bin

# Install 1Password CLI using official RPM repository
RUN rpm --import https://downloads.1password.com/linux/keys/1password.asc && \
    sh -c 'echo -e "[1password]\nname=1Password\nbaseurl=https://downloads.1password.com/linux/rpm/stable/x86_64\nenabled=1\ngpgcheck=1\nrepo_gpgcheck=1\ngpgkey=https://downloads.1password.com/linux/keys/1password.asc" > /etc/yum.repos.d/1password.repo' && \
    dnf install -y 1password-cli && \
    dnf clean all

# Copy test scripts
COPY scripts/ /home/testuser/scripts/
COPY tests/ /home/testuser/tests/
RUN chmod +x /home/testuser/scripts/*.sh /home/testuser/tests/*.sh 2>/dev/null || true

# Set proper ownership
RUN chown -R testuser:testuser /home/testuser

# Switch to test user
USER testuser
WORKDIR /home/testuser

# Set environment
ENV HOME=/home/testuser
ENV USER=testuser

# Default command
CMD ["bash"]
