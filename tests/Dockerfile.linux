# ==============================================================================
# Docker Test Container - Linux (Fixed)
# ==============================================================================
# This Dockerfile is used to test the dotfiles bootstrap on a Linux environment
#
# Build:   docker build -f tests/Dockerfile.linux -t dotfiles-test .
# Run:     docker run --rm dotfiles-test bash tests/test-chezmoi.sh
#
# ==============================================================================

FROM ubuntu:24.04

# Avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Install base dependencies and testing tools
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    vim \
    ca-certificates \
    build-essential \
    procps \
    unzip \
    gpg \
    gnupg \
    python3 \
    python3-yaml \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Create test user FIRST (before installing anything as non-root)
RUN useradd -m -s /bin/bash testuser

# Install chezmoi (works as root)
RUN sh -c "$(curl -fsLS get.chezmoi.io)" -- -b /usr/local/bin

# Install 1Password CLI via apt (as root)
RUN curl -sS https://downloads.1password.com/linux/keys/1password.asc | \
    gpg --dearmor --output /usr/share/keyrings/1password-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/$(dpkg --print-architecture) stable main" | \
    tee /etc/apt/sources.list.d/1password.list && \
    apt-get update && \
    apt-get install -y 1password-cli

# Copy test scripts
COPY scripts/ /home/testuser/scripts/
COPY tests/ /home/testuser/tests/
RUN chmod +x /home/testuser/scripts/*.sh /home/testuser/tests/*.sh 2>/dev/null || true

# Set proper ownership
RUN chown -R testuser:testuser /home/testuser

# Copy entrypoint script (must be done as root)
COPY tests/docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Switch to test user for remaining operations
USER testuser
WORKDIR /home/testuser

# Set environment
ENV HOME=/home/testuser
ENV USER=testuser
ENV OP_SERVICE_ACCOUNT_TOKEN=""

# Default command
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["bash"]
