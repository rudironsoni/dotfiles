# ==============================================================================
# Docker Test Container - Linux
# ==============================================================================
# This Dockerfile is used to test the dotfiles bootstrap on a Linux environment
#
# Build:   docker build -f tests/Dockerfile.linux -t dotfiles-test .
# Run:     docker run --rm dotfiles-test bash tests/test-chezmoi.sh
#
# ==============================================================================

FROM ubuntu:24.04

# Avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Install base dependencies
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    vim \
    ca-certificates \
    build-essential \
    procps \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# Install Homebrew
RUN \
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" && \
    echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"' >> /root/.profile && \
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# Install chezmoi and 1Password CLI via brew
RUN \
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)" && \
    brew install chezmoi 1password-cli

# Create test user (non-root for more realistic testing)
RUN useradd -m -s /bin/bash testuser
WORKDIR /home/testuser

# Copy bootstrap and test scripts
COPY scripts/ /home/testuser/scripts/
COPY tests/test-chezmoi.sh /home/testuser/tests/
RUN chmod +x /home/testuser/scripts/*.sh /home/testuser/tests/*.sh

# Set environment
ENV HOME=/home/testuser
ENV USER=testuser

# Switch to test user
USER testuser

# Default command
CMD ["bash"]
